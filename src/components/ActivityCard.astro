---
interface Props {
  activity: {
    title: string;
    description: string;
    image: string;
  };
}

const { activity } = Astro.props;
---

<article class="rounded-xl overflow-hidden shadow hover:shadow-lg transition bg-white">

  <img
    src={activity.image}
    alt={activity.title}
    class="w-full h-56 object-cover"
  />

  <div class="p-5">

    <h3 class="text-xl font-serif mb-2">
      {activity.title}
    </h3>

    <p class="text-stone-600 text-sm md:text-base leading-relaxed">
      {activity.description}
    </p>

  </div>

</article>
---
import { contactForm } from "../data/contactForm";
---

<section
  class="
    bg-white
    rounded-xl
    shadow
    p-6
    md:p-10
  "
>

  <h2 class="text-2xl md:text-3xl font-serif mb-8">
    ✉️ Nous contacter
  </h2>

  <form
    name="contact"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    class="space-y-6"
  >

    <input
      type="hidden"
      name="form-name"
      value="contact"
    />

    <p hidden>
      <label>
        Ne pas remplir :
        <input name="bot-field" />
      </label>
    </p>

    <!-- Nom prénom -->

    <div>

      <label class="block mb-2 font-medium">
        Nom et prénom
      </label>

      <input
        type="text"
        name="fullname"
        required
        class="
          w-full
          border
          border-stone-300
          rounded-lg
          px-4
          py-3
        "
      />

    </div>

    <!-- Email -->

    <div>

      <label class="block mb-2 font-medium">
        Adresse email
      </label>

      <input
        type="email"
        name="email"
        required
        class="
          w-full
          border
          border-stone-300
          rounded-lg
          px-4
          py-3
        "
      />

    </div>

    <!-- Téléphone -->

    <div>

      <label class="block mb-2 font-medium">
        Téléphone
      </label>

      <input
        type="tel"
        name="phone"
        class="
          w-full
          border
          border-stone-300
          rounded-lg
          px-4
          py-3
        "
      />

    </div>

    <!-- Dates -->

    <div
      class="
        grid
        grid-cols-1
        md:grid-cols-2
        gap-4
      "
    >

      <div>

        <label class="block mb-2 font-medium">
          Arrivée
        </label>

        <input
          type="date"
          name="arrival"
          class="
            w-full
            border
            border-stone-300
            rounded-lg
            px-4
            py-3
          "
        />

      </div>

      <div>

        <label class="block mb-2 font-medium">
          Départ
        </label>

        <input
          type="date"
          name="departure"
          class="
            w-full
            border
            border-stone-300
            rounded-lg
            px-4
            py-3
          "
        />

      </div>

    </div>

    <!-- Motif -->

    <div>

      <label class="block mb-2 font-medium">
        Motif
      </label>

      <select
        name="subject"
        class="
          w-full
          border
          border-stone-300
          rounded-lg
          px-4
          py-3
        "
      >

        {contactForm.motifs.map((motif) => (
          <option value={motif}>
            {motif}
          </option>
        ))}

      </select>

    </div>

    <!-- Message -->

    <div>

      <label class="block mb-2 font-medium">
        Message
      </label>

      <textarea
        name="message"
        rows="6"
        required
        class="
          w-full
          border
          border-stone-300
          rounded-lg
          px-4
          py-3
        "
      ></textarea>

    </div>

    <button
      type="submit"
      class="
        bg-stone-900
        text-white
        px-6
        py-3
        rounded-lg
        hover:bg-stone-700
        transition
      "
    >
      Envoyer la demande
    </button>

  </form>

</section>
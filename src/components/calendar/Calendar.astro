---
import Day from "./Day.astro";
import { buildMonth } from "../../lib/calendar/buildMonth";

const { bookings, roomId } = Astro.props;

const closedDays = new Set();

for (const b of bookings) {
  const start = new Date(b.start);
  const end = new Date(b.end);

  let d = new Date(start);

  while (d < end) {
    closedDays.add(d.toISOString().split("T")[0]);
    d.setDate(d.getDate() + 1);
  }
}

const initialMonth = new Date();
---

<section class="max-w-md mx-auto px-4 py-6">

  <div id={`calendar-root-${roomId}`}></div>

</section>

<script define:vars={{ bookings, initialMonth, roomId }}>
  let current = new Date(initialMonth);

  const buildMonth = (date) => {
    const year = date.getFullYear();
    const month = date.getMonth();

    const first = new Date(year, month, 1);
    const last = new Date(year, month + 1, 0);

    const days = [];

    const startPadding = first.getDay() === 0 ? 6 : first.getDay() - 1;

    for (let i = startPadding; i > 0; i--) {
      days.push(new Date(year, month, 1 - i));
    }

    for (let d = 1; d <= last.getDate(); d++) {
      days.push(new Date(year, month, d));
    }

    return days;
  };

  function render() {
    console.log("roomId", roomId);
    const root = document.getElementById(`calendar-root-${roomId}`);

    const days = buildMonth(current);

    const closedDays = new Set();

    bookings.forEach(b => {
      const start = new Date(b.start);
      const end = new Date(b.end);

      let d = new Date(start);

      while (d < end) {
        closedDays.add(d.toISOString().split("T")[0]);
        d.setDate(d.getDate() + 1);
      }
    });

    const monthLabel = current.toLocaleDateString("fr-FR", {
      month: "long",
      year: "numeric"
    });

    root.innerHTML = `
      <div class="mb-4 flex items-center justify-between">
        <button id="prev-${roomId}" class="px-3 py-1 bg-stone-100 rounded">←</button>
        <h3 class="font-medium">${monthLabel}</h3>
        <button id="next-${roomId}" class="px-3 py-1 bg-stone-100 rounded">→</button>
      </div>

      <div class="grid grid-cols-7 gap-1 text-xs sm:text-sm">
        ${days.map(d => {
          const dateStr = d.toISOString().split("T")[0];
          const isClosed = closedDays.has(dateStr);

          return `
            <div class="aspect-square flex items-center justify-center rounded
              ${isClosed ? "bg-red-500 text-white" : "text-stone-700"}">
              ${d.getDate()}
            </div>
          `;
        }).join("")}
      </div>
    `;

    document.getElementById(`prev-${roomId}`).onclick = () => {
      current.setMonth(current.getMonth() - 1);
      render();
    };

    document.getElementById(`next-${roomId}`).onclick = () => {
      current.setMonth(current.getMonth() + 1);
      render();
    };
  }

  render();
</script>
---
const { images, roomId } = Astro.props;
---

<div class="max-w-4xl mx-auto">

  <!-- image principale -->
  <div class="overflow-hidden rounded-2xl shadow-md">

    <img
      id={`main-image-${roomId}`}
      src={images[0].src}
      alt=""
      class="w-full aspect-[4/3] md:aspect-[16/9] object-cover"
    />

  </div>

  <!-- dots mobile -->
  <div
    id={`dots-${roomId}`}
    class="flex justify-center gap-2 mt-4"
  >
    {images.map((_: any, index: number) => (
      <button
        class={`w-2 h-2 rounded-full ${
          index === 0
            ? "bg-stone-900"
            : "bg-stone-300"
        }`}
        data-room={roomId}
        data-index={index}
      />
    ))}
  </div>

  <!-- miniatures -->
  <div class="grid grid-cols-4 md:grid-cols-5 gap-2 mt-4">

    {images.map((image: any, index: number) => (
      <button
        class="
          overflow-hidden
          rounded-xl
          border
          border-stone-200
        "
        data-room={roomId}
        data-index={index}
      >
        <img
          src={image.src}
          alt=""
          class="
            w-full
            h-16
            md:h-20
            object-cover
            hover:scale-105
            transition
          "
        />
      </button>
    ))}

  </div>

</div>

<script define:vars={{ images, roomId }}>

  let current = 0;

  const mainImage =
    document.getElementById(`main-image-${roomId}`);

  const dots =
    document.getElementById(`dots-${roomId}`);

  function update() {

    if (!mainImage) return;

    mainImage.src = images[current].src;

    dots?.querySelectorAll("button")
      .forEach((dot, i) => {

        dot.className =
          i === current
            ? "w-2 h-2 rounded-full bg-stone-900"
            : "w-2 h-2 rounded-full bg-stone-300";
      });
  }

  document
    .querySelectorAll(`[data-room="${roomId}"]`)
    .forEach((button) => {

      button.addEventListener("click", () => {

        current = Number(
          button.getAttribute("data-index")
        );

        update();
      });
    });

  // Swipe mobile

  let startX = 0;

  mainImage?.addEventListener("touchstart", (e) => {

    startX = e.touches[0].clientX;

  });

  mainImage?.addEventListener("touchend", (e) => {

    const endX = e.changedTouches[0].clientX;

    const diff = startX - endX;

    if (diff > 50) {

      current =
        (current + 1) % images.length;

      update();
    }

    if (diff < -50) {

      current =
        (current - 1 + images.length)
        % images.length;

      update();
    }
  });

</script>
---
interface Props {
  room: {
    name: string;
    subtitle: string;
    description: string[];
    images: string[];
  };
}

const { room } = Astro.props;
---

<section class="py-12">

  <div class="max-w-5xl mx-auto px-4">

    <!-- TITRE -->
    <h2 class="text-3xl md:text-4xl font-serif mb-2">
      {room.name}
    </h2>

    <p class="text-stone-600 mb-6">
      {room.subtitle}
    </p>

    <!-- IMAGES (mobile first stack) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">

      {room.images.map((img) => (
        <img
          src={img}
          alt={room.name}
          class="w-full h-64 md:h-80 object-cover rounded-xl shadow"
        />
      ))}

    </div>

    <!-- TEXTE -->
    <div class="space-y-4 text-base md:text-lg leading-relaxed">

      {room.description.map((text) => (
        <p>{text}</p>
      ))}

    </div>

  </div>

</section>
---
import Calendar from "./calendar/Calendar.astro";
import ImageCarousel from "./carousel/ImageCarousel.astro";

const { room } = Astro.props;
---

<article
  class="
    bg-white
    rounded-3xl
    shadow-sm
    overflow-hidden
    border
    border-stone-200
  "
>

  <!-- Photos -->
  <div class="p-4 md:p-6">
    <ImageCarousel
      images={room.images}
      roomId={room.id}
    />
  </div>

  <!-- Contenu -->
  <div class="px-5 pb-6">

    <h2
      class="
        text-2xl
        md:text-3xl
        font-serif
      "
    >
      {room.name}
    </h2>

    <p
      class="
        text-stone-500
        mt-2
      "
    >
      {room.subtitle}
    </p>

    <div
      class="
        mt-6
        space-y-4
        text-stone-700
      "
    >
      {room.description.map((paragraph: unknown) => (
        <p>{paragraph}</p>
      ))}
    </div>

    <div class="mt-6">
          <Calendar
            bookings={room.bookings}
            roomId={room.id}
          />
        </div>

  </div>

</article>
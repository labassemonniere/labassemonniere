---
import ImageCarousel from "./carousel/ImageCarousel.astro";

const { room } = Astro.props;
console.log(room.images);
---

<section class="max-w-6xl mx-auto px-4">

  
  <div class="mt-8">
    <h2 class="text-3xl font-serif">
      {room.name}
    </h2>
    
    <p class="text-stone-500 mt-2">
      {room.subtitle}
    </p>
    
    
    
    <div class="mt-6 space-y-4">
      {room.description.map((paragraph: string) => (
        <p class="text-stone-700 leading-relaxed">
          {paragraph}
        </p>
      ))}
    </div>
    
    <ImageCarousel
      images={room.images}
      roomId={room.id}
    />
  </div>

</section>
---
const { roomId } = Astro.props;
---

<section class="max-w-5xl mx-auto px-4 py-12">

  <h2 class="text-3xl font-serif mb-6 text-center" >
    Disponibilités
  </h2>

  <div id={`calendar-${roomId}`} class="text-sm">
    Chargement...
  </div>

</section>

<script define:vars={{ roomId }}>
  async function load() {
    const res = await fetch(`/services/bookings.json?roomId=${roomId}`);
    const data = await res.json();

    const calendrier = document.getElementById(`calendar-${roomId}`);

    if (calendrier) {
        calendrier.innerHTML = JSON.stringify(data, null, 2);
    }
  }
  load();
</script>
